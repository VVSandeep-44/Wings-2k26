{
  "name": "wings-2k26",
  "version": "1.0.0",
  "description": "WINGS 2k26 event website with backend API and MongoDB database",
  "main": "server.js",
  "scripts": {
    "build:netlify": "npm install --prefix client && npm run build --prefix client",
    "start": "node server.js",
    "dev": "node server.js",
    "client:install": "cd client && npm install",
    "client:dev": "cd client && npm run dev",
    "client:build": "cd client && npm run build",
    "build": "npm run client:build"
  },
  "dependencies": {
    "@sentry/node": "^8.45.0",
    "cors": "^2.8.5",
    "dotenv": "^16.6.1",
    "express": "^4.21.2",
    "libphonenumber-js": "^1.11.16",
    "mongodb": "^6.16.0",
    "newrelic": "^12.20.0",
    "node-html-to-image": "^5.0.0",
    "react-icons": "^5.6.0",
    "validator": "^13.12.0"
  }
}
