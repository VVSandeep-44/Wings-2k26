# =========================
# Local development template
# Copy to .env and fill values
# =========================

# Core app
NODE_ENV=development
PORT=3000
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# MongoDB
MONGODB_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/wings2k26?retryWrites=true&w=majority
MONGODB_DB_NAME=wings2k26

# Brevo
BREVO_API_KEY=<your_brevo_api_key>
INVITE_FROM_EMAIL=<verified_sender@example.com>

# Admin
ADMIN_PASSWORD=<strong_admin_password>
ADMIN_SESSION_TOKEN=<long_random_session_token>

# Sentry (backend)
SENTRY_DSN=
SENTRY_ENVIRONMENT=development
SENTRY_TRACES_SAMPLE_RATE=0.1

# Sentry (browser) - optional for React client (set as VITE_SENTRY_BROWSER_DSN in Netlify)
SENTRY_BROWSER_DSN=

# New Relic
NEW_RELIC_ENABLED=true
NEW_RELIC_LICENSE_KEY=
NEW_RELIC_APP_NAME=WINGS 2k26 API
NEW_RELIC_NO_CONFIG_FILE=true
